# Copy to .env (or set in your shell / launcher) — do NOT commit the real values.

# Required: absolute path to your Obsidian vault (or any folder of .md files)
VAULT_PATH=/path/to/your/obsidian/vault

# Optional: where to store the SQLite index + embedding cache.
# Defaults to $XDG_DATA_HOME/obsidian-brain or ~/.local/share/obsidian-brain
# DATA_DIR=/path/to/data/dir

# Optional: embedding model. Default: Xenova/all-MiniLM-L6-v2 (384 dims, ~22MB).
# Switching auto-reindexes — the server records the active model in the DB
# and rebuilds chunks_vec the next time it starts under a new identifier.
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# Alternatives (all auto-reindex on switch):
#   Xenova/bge-small-en-v1.5                      (384d, better quality)
#   Xenova/bge-base-en-v1.5                       (768d, best CPU quality)
#   Xenova/paraphrase-multilingual-MiniLM-L12-v2  (384d, multilingual)

# Embedding provider — default is "transformers" (local, no setup). Set to
# "ollama" to use a local Ollama server for higher-quality embeddings.
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# With EMBEDDING_PROVIDER=ollama, EMBEDDING_MODEL selects the Ollama model
# (default: nomic-embed-text). Pull it first with: ollama pull <model>.
# OLLAMA_EMBEDDING_DIM is optional — if unset the server probes the model
# on startup. Well-known dims:
#   nomic-embed-text      = 768
#   mxbai-embed-large     = 1024
#   bge-large             = 1024
#   qwen3-embedding-8b    = 4096
# OLLAMA_EMBEDDING_DIM=768
