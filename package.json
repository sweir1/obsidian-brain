{
  "name": "obsidian-brain",
  "version": "1.6.3",
  "mcpName": "io.github.sweir1/obsidian-brain",
  "description": "Standalone Node MCP server: semantic search + knowledge graph + vault editing for Obsidian, no plugin required.",
  "type": "module",
  "license": "MIT",
  "author": "sweir1",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "obsidian",
    "semantic-search",
    "knowledge-graph",
    "embeddings",
    "claude",
    "claude-desktop",
    "claude-code",
    "vault",
    "markdown",
    "graphology",
    "sqlite"
  ],
  "homepage": "https://github.com/sweir1/obsidian-brain#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sweir1/obsidian-brain.git"
  },
  "bugs": {
    "url": "https://github.com/sweir1/obsidian-brain/issues"
  },
  "bin": {
    "obsidian-brain": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "cli": "tsx src/cli/index.ts",
    "dev": "tsx src/cli/index.ts server",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx scripts/mcp-smoke.ts",
    "prepublishOnly": "npm run build",
    "version": "node scripts/sync-server-version.mjs && git add server.json",
    "postversion": "git push --follow-tags"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^4.0.3",
    "commander": "^14.0.3",
    "diff": "^8.0.4",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.4.0",
    "graphology-types": "^0.24.8",
    "gray-matter": "^4.0.3",
    "sqlite-vec": "^0.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
